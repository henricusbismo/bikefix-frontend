---
export async function getStaticPaths() {
  const apiUrl = import.meta.env.WORDPRESS_API_URL || 'https://bikefixdb.biz.id/?rest_route=';
  const targetUrl = `${apiUrl}/wp/v2/symptoms&per_page=100`;
  
  console.log(`DIAGNOSTIC: Attempting to fetch from: ${targetUrl}`);
  
  try {
    const res = await fetch(targetUrl);
    const textData = await res.text();
    
    console.log(`DIAGNOSTIC: Raw API Response Payload (First 500 chars): ${textData.slice(0, 500)}`);
    
    // Parse the data manually so we don't crash if it's bad data
    const posts = JSON.parse(textData);
    
    if (Array.isArray(posts) && posts.length > 0) {
      return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
      }));
    } else {
      console.log("DIAGNOSTIC: Response parsed as JSON but array was empty or invalid.");
    }
  } catch (error) {
    console.error("DIAGNOSTIC: Processing failed completely with error:", error);
  }

  // Backup placeholder so the pipeline doesn't break
  return [
    {
      params: { slug: 'president-indonesia' },
      props: { 
        post: { 
          title: { rendered: 'President Indonesia 66' }, 
          content: { rendered: '<p>Testing dynamic automated deployment system sync payload.</p>' } 
        } 
      }
    }
  ];
}

const { post } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{post?.title?.rendered || 'Loading...'}</title>
</head>
<body>
    <a href="/">← Back to Home</a>
    <h1>{post.title.rendered}</h1>
    <div class="content" set:html={post.content.rendered} />
</body>
</html>