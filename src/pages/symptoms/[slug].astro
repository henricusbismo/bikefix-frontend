---
export async function getStaticPaths() {
  try {
    const res = await fetch('https://bikefixdb.biz.id/wp-json/wp/v2/posts'); // Or /wp/v2/symptoms depending on your custom post type
    const posts = await res.json();
    
    if (Array.isArray(posts) && posts.length > 0) {
      return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
      }));
    }
  } catch (e) {
    console.log("Local WordPress API offline during GitHub build. Using static path fallbacks.");
  }

  // Guaranteed fallback paths so your site never builds broken 404 pages
  return [
    {
      params: { slug: 'president-indonesia' },
      props: { 
        post: { 
          title: { rendered: 'President Indonesia 66' }, 
          content: { rendered: '<p>Testing dynamic automated deployment system sync payload.</p>' } 
        } 
      }
    },
    {
      params: { slug: 'trek-marlin-brake-squeal-causes-fixes-owner-reported' },
      props: { 
        post: { 
          title: { rendered: 'Trek Marlin Brake Squeal: Causes, Fixes (Owner-Reported)' }, 
          content: { rendered: '<p>Brake troubleshooting content goes here.</p>' } 
        } 
      }
    }
  ];
}

const { post } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{post.title.rendered}</title>
    <style>
        body {
            font-family: system-ui, sans-serif;
            max-width: 800px;
            margin: 40px auto;
            padding: 0 20px;
            line-height: 1.6;
            color: #333;
        }
        h1 {
            color: #111;
            border-bottom: 2px solid #eee;
            padding-bottom: 10px;
        }
        .content {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <a href="/">← Back to Home</a>
    <h1>{post.title.rendered}</h1>
    <div class="content" set:html={post.content.rendered} />
</body>
</html>