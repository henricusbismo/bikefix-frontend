---
export async function getStaticPaths() {
  // Pulls the endpoint URL from your deploy.yml or falls back to the query string layout
  const apiUrl = import.meta.env.WORDPRESS_API_URL || 'https://bikefixdb.biz.id/?rest_route=';
  
  try {
    // Appending /wp/v2/posts onto our query string API base route cleanly
    const res = await fetch(`${apiUrl}/wp/v2/posts&per_page=100`);
    
    const contentType = res.headers.get("content-type");
    if (!contentType || !contentType.includes("application/json")) {
      console.error(`API Error: Expected JSON but received content-type: ${contentType}`);
      return [];
    }

    const posts = await res.json();
    if (Array.isArray(posts)) {
      return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
      }));
    }
  } catch (error) {
    console.error("Failed to fetch posts at build time:", error);
  }

  return [];
}

const { post } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{post?.title?.rendered || 'Loading...'}</title>
    <style>
        body {
            font-family: system-ui, sans-serif;
            max-width: 800px;
            margin: 40px auto;
            padding: 0 20px;
            line-height: 1.6;
            color: #333;
        }
        h1 {
            color: #111;
            border-bottom: 2px solid #eee;
            padding-bottom: 10px;
        }
        .content {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    {post ? (
      <a href="/">← Back to Home</a>
      <h1>{post.title.rendered}</h1>
      <div class="content" set:html={post.content.rendered} />
    ) : (
      <h1>Post compilation error</h1>
      <p>Check GitHub log streams for API payload diagnostics.</p>
    )}
</body>
</html>