---
export async function getStaticPaths() {
	// Fallback to the live link domain if variable isn't configured in github secrets environment yet
	const apiUrl = import.meta.env.WORDPRESS_API_URL || "https://macho-newsletter.localsite.io/wp-json/wp/v2";
	const username = 'journey';
	const password = 'robust';
	const token = btoa(`${username}:${password}`);

	try {
		const response = await fetch(`${apiUrl}/symptoms?per_page=100`, {
			headers: { 'Authorization': `Basic ${token}` },
			signal: AbortSignal.timeout(8000)
		});
		
		if (!response.ok) throw new Error(`WordPress returned status ${response.status}`);
		const posts = await response.json();
		if (!Array.isArray(posts)) return [];

		return posts.map((post) => ({
			params: { slug: post.slug },
			props: { post },
		}));
	} catch (error) {
		console.error("Static path generation failed. Cloud runner cannot access local instance:", error.message);
		return []; // Return empty array to stop old mock items from leaking into structure
	}
}

const { post } = Astro.props;
if (!post) return Astro.redirect('/404'); // Handle invalid route compilations smoothly

const rawTitle = post.title.rendered;
const rawContent = post.content.rendered;
const formattedDate = new Date(post.date).toLocaleDateString();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{rawTitle}</title>
		<style>
			body { 
				font-family: system-ui, -apple-system, sans-serif; 
				max-width: 800px; 
				margin: 40px auto; 
				padding: 20px; 
				color: #222;
				line-height: 1.6;
			}
			a { color: #0066cc; text-decoration: none; }
			a:hover { text-decoration: underline; }
			.meta { color: #666; margin-bottom: 20px; font-size: 0.9rem; }
			h1 { font-size: 2.2rem; color: #111; margin-bottom: 5px; }
		</style>
	</head>
	<body>
		<p><a href="/">← Back to All Symptoms</a></p>
		
		<header>
			<h1>{rawTitle}</h1>
			<p class="meta">Published: {formattedDate}</p>
		</header>

		<hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;" />

		<main>
			<Fragment set:html={rawContent} />
		</main>
	</body>
</html>