---
export async function getStaticPaths() {
  // Pulls the live link URL you set inside your deploy.yml environment variables
  const apiUrl = import.meta.env.WORDPRESS_API_URL || 'https://bikefixdb.biz.id/wp-json';
  
  // Fetching the dynamic data from your live link endpoint
  const res = await fetch(`${apiUrl}/wp/v2/posts?per_page=100`);
  const posts = await res.json();
  
  // This maps every single live post dynamically into its own URL route page
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// Destructure the individual post properties passed down from getStaticPaths
const { post } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{post.title.rendered}</title>
    <style>
        body {
            font-family: system-ui, sans-serif;
            max-width: 800px;
            margin: 40px auto;
            padding: 0 20px;
            line-height: 1.6;
            color: #333;
        }
        h1 {
            color: #111;
            border-bottom: 2px solid #eee;
            padding-bottom: 10px;
        }
        .content {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <a href="/">← Back to Home</a>
    <h1>{post.title.rendered}</h1>
    
    <!-- This renders the actual raw HTML content field directly from your WordPress database -->
    <div class="content" set:html={post.content.rendered} />
</body>
</html>