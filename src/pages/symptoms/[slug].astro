---
export async function getStaticPaths() {
	const apiUrl = import.meta.env.WORDPRESS_API_URL;
	const username = 'journey';
	const password = 'robust';
	const token = btoa(`${username}:${password}`);

	try {
		const response = await fetch(`${apiUrl}/symptoms?per_page=100`, {
			headers: { 'Authorization': `Basic ${token}` },
			signal: AbortSignal.timeout(5000)
		});
		
		if (!response.ok) throw new Error(`WordPress returned status ${response.status}`);
		const posts = await response.json();
		if (!Array.isArray(posts)) return [];

		return posts.map((post) => ({
			params: { slug: post.slug },
			props: { post },
		}));
	} catch (error) {
		// Bypasses the local host network barrier during GitHub cloud builds
		console.warn("Skipping dynamic path generation on offline build container:", error.message);
		return [];
	}
}

const { post } = Astro.props;
const rawTitle = post?.title?.rendered || "Demo Symptom Guide";
const rawContent = post?.content?.rendered || "<p>This is placeholder content because the build runner is offline.</p>";
const formattedDate = post?.date ? new Date(post.date).toLocaleDateString() : "June 25, 2026";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{rawTitle}</title>
		<style>
			body { 
				font-family: sans-serif; 
				max-width: 800px; 
				margin: 40px auto; 
				padding: 20px; 
				color: #222;
				background-color: #ffffff;
			}
			a { color: #0066cc; }
			.meta { color: #666; margin-bottom: 20px; }
			main * {
				display: block !important;
				visibility: visible !important;
				opacity: 1 !important;
				color: #222 !important;
			}
		</style>
	</head>
	<body>
		<p><a href="/">← Back to All Symptoms</a></p>
		
		<header>
			<h1>{rawTitle}</h1>
			<p class="meta">Published: {formattedDate}</p>
		</header>

		<hr />

		<main>
			<Fragment set:html={rawContent} />
		</main>
	</body>
</html>