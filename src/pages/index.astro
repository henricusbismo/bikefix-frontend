---
const apiUrl = import.meta.env.WORDPRESS_API_URL || 'https://macho-newsletter.localsite.io/?rest_route=';
const basicAuth = btoa('journey:robust');

let posts = [];
try {
  const res = await fetch(`${apiUrl}/wp/v2/symptoms&per_page=100&_embed`, {
    headers: { 'Authorization': `Basic ${basicAuth}` }
  });
  posts = await res.json();
} catch (e) {
  console.error("Home page fetch failed", e);
}

const formatDate = (dateStr) => {
  if (!dateStr) return 'Updated recently';
  const date = new Date(dateStr);
  return `Updated ${date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;
};
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bike Fix Directory - All Reviews</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
    
    <style>
        body { 
            font-family: 'Inter', sans-serif; 
            max-width: 1040px; 
            margin: 0 auto; 
            padding: 20px; 
            color: #1a1a1a;
            background-color: #ffffff;
        }
        .disclaimer {
            text-align: center;
            font-size: 0.85rem;
            color: #555;
            border-bottom: 1px solid #e0e0e0;
            padding-bottom: 15px;
            margin-bottom: 30px;
        }
        .disclaimer strong { color: #111; }
        h1.section-title { 
            font-family: 'Playfair Display', serif; 
            font-size: 2.5rem; 
            font-weight: 800;
            margin-bottom: 40px;
            color: #111;
        }
        .articles-list { 
            display: flex;
            flex-direction: column;
            gap: 35px;
        }
        .article-card { 
            display: flex;
            gap: 30px;
            align-items: flex-start;
            padding-bottom: 35px;
            border-bottom: 1px solid #f0f0f0;
        }
        .thumbnail-wrapper {
            flex-shrink: 0;
            width: 280px;
            height: 180px;
            background-color: #f7f7f7;
            overflow: hidden;
            border-radius: 2px;
        }
        .thumbnail-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .content-block {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .article-title {
            font-size: 1.4rem;
            font-weight: 700;
            line-height: 1.25;
            margin: 0;
        }
        .article-title a {
            color: #111111;
            text-decoration: none;
        }
        .article-title a:hover {
            color: #0066cc;
            text-decoration: underline;
        }
        .excerpt {
            font-size: 1rem;
            color: #4a4a4a;
            line-height: 1.5;
            margin: 0;
        }
        .updated-date {
            font-size: 0.85rem;
            color: #666666;
            font-weight: 500;
            margin: 0;
            margin-top: 4px;
        }
        @media (max-width: 680px) {
            .article-card { flex-direction: column; gap: 15px; }
            .thumbnail-wrapper { width: 100%; height: 200px; }
        }
    </style>
</head>
<body>

    <div class="disclaimer">
        We independently review everything we recommend. When you buy through our links, we may earn a commission. <strong>Learn more ›</strong>
    </div>

    <h1 class="section-title">All Reviews</h1>

    <main class="articles-list">
        {Array.isArray(posts) && posts.map((post) => {
            let brandSlug = '';
            let modelSlug = '';
            
            const embeddedTerms = post._embedded?.['wp:term'] || [];
            embeddedTerms.forEach((taxonomyGroup) => {
              if (Array.isArray(taxonomyGroup)) {
                taxonomyGroup.forEach((term) => {
                  if (term.taxonomy === 'brands') brandSlug = term.slug;
                  if (term.taxonomy === 'models') modelSlug = term.slug;
                });
              }
            });

            const hrefPath = brandSlug 
                ? `/${brandSlug}/${modelSlug ? modelSlug : 'all'}/${post.slug}` 
                : `/${post.slug}`;

            const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;

            return (
                <article class="article-card">
                    <div class="thumbnail-wrapper">
                        {featuredImage ? (
                            <img src={featuredImage} alt={post.title?.rendered} loading="lazy" />
                        ) : (
                            <div style="width:100%; height:100%; background:#eaeaea; display:flex; align-items:center; justify-content:center; color:#999; font-size:0.9rem;">No Image</div>
                        )}
                    </div>

                    <div class="content-block">
                        <h2 class="article-title">
                            <a href={hrefPath} set:html={post.title?.rendered} />
                        </h2>
                        <div class="excerpt" set:html={post.excerpt?.rendered || 'Read details...'} />
                        <p class="updated-date">{formatDate(post.date)}</p>
                    </div>
                </article>
            );
        })}
    </main>

</body>
</html>