{Array.isArray(posts) && posts.map((post) => {
            let brandSlug = '';
            let modelSlug = '';
            
            const embeddedTerms = post._embedded?.['wp:term'] || [];
            embeddedTerms.forEach((taxonomyGroup) => {
              if (Array.isArray(taxonomyGroup)) {
                taxonomyGroup.forEach((term) => {
                  if (term.taxonomy === 'brands') brandSlug = term.slug;
                  if (term.taxonomy === 'models') modelSlug = term.slug;
                });
              }
            });

            const hrefPath = brandSlug 
                ? `/${brandSlug}/${modelSlug ? modelSlug : 'all'}/${post.slug}` 
                : `/${post.slug}`;

            const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;

            return (
                <article class="article-card">
                    <div class="thumbnail-wrapper">
                        {featuredImage ? (
                            <img src={featuredImage} alt={post.title.rendered} loading="lazy" />
                        ) : (
                            <div style="width:100%; height:100%; background:#eaeaea; display:flex; align-items:center; justify-content:center; color:#999; font-size:0.9rem;">No Image</div>
                        )}
                    </div>
                    <div class="content-block">
                        <h2 class="article-title">
                            <a href={hrefPath} set:html={post.title.rendered} />
                        </h2>
                        <div class="excerpt" set:html={post.excerpt?.rendered || 'Read details...'} />
                        <p class="updated-date">Updated</p>
                    </div>
                </article>
            );
        })}