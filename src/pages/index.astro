---
const apiUrl = import.meta.env.WORDPRESS_API_URL || 'https://macho-newsletter.localsite.io/?rest_route=/';
const basicAuth = btoa('journey:robust');

let registeredRoutes = [];
let connectionStatus = "";

try {
  const res = await fetch(apiUrl, {
    headers: { 'Authorization': `Basic ${basicAuth}` }
  });
  
  connectionStatus = `Connected Successfully (Status: ${res.status})`;
  const data = await res.json();
  
  if (data && data.routes) {
    // Extract every route registered under wp/v2
    registeredRoutes = Object.keys(data.routes).filter(route => route.includes('wp/v2'));
  }
} catch (e) {
  connectionStatus = `Connection Failed: ${e.message}`;
}
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WordPress API Route Scanner</title>
    <style>
        body { font-family: monospace; padding: 40px; background: #0f172a; color: #e2e8f0; line-height: 1.5; }
        .container { max-width: 800px; margin: 0 auto; }
        .status { padding: 15px; background: #1e293b; border-left: 4px solid #10b981; margin-bottom: 20px; border-radius: 4px; }
        .route-list { background: #1e293b; padding: 20px; border-radius: 4px; border: 1px solid #334155; }
        .route-item { padding: 6px 0; border-bottom: 1px solid #334155; color: #38bdf8; }
        .highlight { color: #f59e0b; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <h2>🔍 Live WordPress Route Map Scanner</h2>
        <div class="status">
            <strong>Connection Status:</strong> {connectionStatus}
        </div>

        <h3>Available URL Ends Found under /wp/v2/:</h3>
        <div class="route-list">
            {registeredRoutes.length === 0 ? (
                <p>No routes found. Ensure your custom post types are fully public.</p>
            ) : (
                registeredRoutes.map(route => (
                    <div class="route-item">
                        {route.includes('symptom') ? <span class="highlight">👉 {route} 👈</span> : route}
                    </div>
                ))
            )}
        </div>
    </div>
</body>
</html>