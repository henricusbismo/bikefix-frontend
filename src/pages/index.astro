---
// Fetching the posts on the homepage with _embed so links can read the categories
const apiUrl = import.meta.env.WORDPRESS_API_URL || 'https://macho-newsletter.localsite.io/?rest_route=';
const basicAuth = btoa('journey:robust');

let posts = [];
try {
  const res = await fetch(`${apiUrl}/wp/v2/symptoms&per_page=100&_embed`, {
    headers: { 'Authorization': `Basic ${basicAuth}` }
  });
  posts = await res.json();
} catch (e) {
  console.error("Home page fetch failed", e);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bike Fix Directory</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 800px; margin: 40px auto; padding: 0 20px; }
        ul { padding: 0; list-style: none; }
        li { margin: 15px 0; }
        a { color: #0066cc; text-decoration: none; font-size: 1.2rem; font-weight: bold; }
        a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <h1>Symptoms Directory</h1>
    <ul>
        {Array.isArray(posts) && posts.map((post) => {
            const terms = post._embedded?.['wp:term']?.[0] || [];
            const childCat = terms.find(term => term.parent !== 0);
            const parentCat = terms.find(term => term.parent === 0);
            
            // Build matching link paths dynamically
            const hrefPath = parentCat 
                ? `/${parentCat.slug}/${childCat ? childCat.slug : 'all'}/${post.slug}` 
                : `/${post.slug}`;

            return (
                <li>
                    <a href={hrefPath}>{post.title.rendered}</a>
                </li>
            );
        })}
    </ul>
</body>
</html>