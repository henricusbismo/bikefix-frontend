---
// 1. Grab the clean base API URL from your .env file
const apiUrl = import.meta.env.WORDPRESS_API_URL;

// 2. Set up your basic authentication keys from your LocalWP credentials
const username = 'journey';
const password = 'robust';
const token = btoa(`${username}:${password}`);

let posts = [];
let debugMessage = "";

try {
	// Fetch the 10 most recent entries from your Custom Post Type (symptoms)
	const response = await fetch(`${apiUrl}/symptoms?per_page=10`, {
		headers: {
			'Authorization': `Basic ${token}`
		}
	});
	
	const data = await response.json();
	
	// Check if the response is an array of articles or a WordPress API error object
	if (Array.isArray(data)) {
		posts = data;
		if (posts.length === 0) {
			debugMessage = "Connected successfully! However, your database returned 0 symptoms. Make sure your articles under the 'Symptoms' tab are explicitly set to 'Published'.";
		}
	} else {
		debugMessage = `WordPress API Error: ${data.message || JSON.stringify(data)}`;
	}
} catch (error) {
	debugMessage = `Failed to reach the LocalWP tunnel. Ensure your Local app is open and 'Live Link' is active. Error: ${error.message}`;
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>My Bike Fix Database</title>
		<style>
			body { 
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
				max-width: 800px; 
				margin: 40px auto; 
				padding: 0 20px; 
				line-height: 1.6; 
				color: #333;
			}
			h1 { 
				color: #111; 
				border-bottom: 2px solid #eee; 
				padding-bottom: 10px; 
				margin-bottom: 30px;
			}
			.debug-box {
				color: #333; 
				background: #fff9db; 
				padding: 15px; 
				border-left: 4px solid #f59f00;
				border-radius: 4px;
				margin-bottom: 30px;
				font-weight: 500;
			}
			.post-card { 
				margin-bottom: 40px; 
				padding-bottom: 20px;
				border-bottom: 1px solid #eee;
			}
			.post-card h2 { 
				margin-bottom: 5px; 
				color: #0066cc; 
				font-size: 1.6rem;
			}
			.post-card small { 
				color: #777; 
				display: block;
				margin-bottom: 15px;
			}
			.post-content {
				margin-top: 15px;
			}
		</style>
	</head>
	<body>
		<h1>Bike Fix Database — Latest Symptoms</h1>

		{debugMessage && <div class="debug-box">{debugMessage}</div>}

		<div>
			{posts.map((post) => (
				<article class="post-card">
					{/* 1. Render the title, or use a default if WordPress CPT handles titles differently */}
					<h2>{post.title?.rendered ? <span dangerouslySetInnerHTML={{ __html: post.title.rendered }} /> : "Trek Marlin Brake Squeal"}</h2>
					
					<small>Published: {post.date ? new Date(post.date).toLocaleDateString() : "Unknown Date"}</small>
					
					{/* 2. Show the complete core content section of the article body safely */}
					{post.content?.rendered ? (
						<div class="post-content" dangerouslySetInnerHTML={{ __html: post.content.rendered }}></div>
					) : (
						<p>No content body found inside this article entry.</p>
					)}
				</article>
			))}
		</div>
	</body>
</html>