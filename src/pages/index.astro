---
const apiUrl = import.meta.env.WORDPRESS_API_URL || 'https://macho-newsletter.localsite.io/?rest_route=';
const basicAuth = btoa('journey:robust');

let posts = [];
try {
  const res = await fetch(`${apiUrl}/wp/v2/symptoms&per_page=100&_embed`, {
    headers: { 'Authorization': `Basic ${basicAuth}` }
  });
  posts = await res.json();
} catch (e) {
  console.error("Home page fetch failed", e);
}

const formatDate = (dateStr) => {
  if (!dateStr) return 'Updated recently';
  const date = new Date(dateStr);
  return `Updated ${date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;
};
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bike Fix Directory - All Reviews</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
    
    <style>
        /* Exact Wirecutter Global Styles */
        body { 
            font-family: 'Inter', sans-serif; 
            max-width: 1140px; 
            margin: 0 auto; 
            padding: 0 24px; 
            color: #000000;
            background-color: #ffffff;
            -webkit-font-smoothing: antialiased;
        }

        /* 1. Main Header Row Matrix */
        .site-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 24px 0 16px 0;
            gap: 32px;
        }

        /* Logo Group: T | Wirecutter Structure */
        .logo-container {
            display: flex;
            align-items: center;
            text-decoration: none;
            color: #000000;
        }
        .logo-t {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            font-weight: 900;
            margin-right: 8px;
            line-height: 1;
        }
        .logo-divider {
            width: 1px;
            height: 22px;
            background-color: #cccccc;
            margin-right: 8px;
        }
        .logo-text {
            font-family: 'Playfair Display', serif;
            font-size: 1.75rem;
            font-weight: 900;
            letter-spacing: -0.8px;
            line-height: 1;
        }

        /* 2. Exact Rounded Search Box Component Layout */
        .search-container {
            flex-grow: 1;
            max-width: 580px;
            position: relative;
            display: flex;
            align-items: center;
        }
        .search-input {
            width: 100%;
            height: 40px;
            padding: 0 16px 0 165px; /* Perfect sizing gap to fit the search badge text */
            font-size: 0.92rem;
            border: 1px solid #000000;
            border-radius: 20px; /* Perfect Pill Shape */
            font-family: 'Inter', sans-serif;
            outline: none;
            box-sizing: border-box;
            color: #000000;
        }
        .search-input::placeholder {
            color: #999999;
            font-size: 0.92rem;
        }
        .search-badge {
            position: absolute;
            left: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: 700;
            font-size: 0.88rem;
            color: #000000;
            pointer-events: none;
            white-space: nowrap;
        }
        .search-badge .star-icon {
            color: #4f46e5; /* Precise purple sparkle color */
            font-size: 1.2rem;
            line-height: 1;
        }

        /* 3. Auth Buttons Layout Group */
        .auth-actions {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-shrink: 0;
        }
        .btn-signup {
            font-size: 0.88rem;
            font-weight: 600;
            color: #000000;
            text-decoration: none;
        }
        .btn-login {
            font-size: 0.88rem;
            font-weight: 700;
            background: #000000;
            color: #ffffff;
            padding: 8px 16px;
            border-radius: 4px;
            text-decoration: none;
        }

        /* 4. Navigation Menu Bar Styles */
        .nav-menu {
            display: flex;
            justify-content: space-between;
            padding: 12px 0 24px 0;
            overflow-x: auto;
            gap: 16px;
            scrollbar-width: none;
        }
        .nav-menu::-webkit-scrollbar { display: none; }
        .nav-link {
            font-size: 0.95rem;
            font-weight: 700; /* Crisp bold look */
            color: #000000;
            text-decoration: none;
            white-space: nowrap;
        }
        .nav-link:hover {
            color: #0066cc;
        }

        /* 5. Disclaimer Panel Section Layout */
        .disclaimer-section {
            background-color: #f9f9f9; /* Subtle off-white row wrap layout */
            padding: 14px 0;
            text-align: center;
        }
        .disclaimer-text {
            font-size: 0.85rem;
            color: #333333;
            margin: 0;
            line-height: 1.4;
        }
        .disclaimer-text strong {
            color: #000000;
            text-decoration: underline;
            cursor: pointer;
        }

        /* 6. Sharp Global Dividing Line Row */
        .header-bottom-line {
            border: none;
            border-top: 1.5px solid #000000; /* Strong crisp baseline splitter component */
            margin: 16px 0 40px 0;
            padding: 0;
        }

        /* Feed Cards Styles */
        h1.section-title { 
            font-family: 'Playfair Display', serif; 
            font-size: 2.5rem; 
            font-weight: 800;
            margin-bottom: 40px;
        }
        .articles-list { 
            display: flex;
            flex-direction: column;
            gap: 35px;
        }
        .article-card { 
            display: flex;
            gap: 30px;
            align-items: flex-start;
            padding-bottom: 35px;
            border-bottom: 1px solid #f0f0f0;
        }
        .thumbnail-wrapper {
            flex-shrink: 0;
            width: 280px;
            height: 180px;
            background-color: #f7f7f7;
            overflow: hidden;
        }
        .thumbnail-wrapper img { width: 100%; height: 100%; object-fit: cover; }
        .content-block { display: flex; flex-direction: column; gap: 8px; }
        .article-title { font-size: 1.4rem; font-weight: 700; margin: 0; }
        .article-title a { color: #000000; text-decoration: none; }
        .article-title a:hover { color: #0066cc; text-decoration: underline; }
        .excerpt { font-size: 1rem; color: #4a4a4a; line-height: 1.5; margin: 0; }
        .updated-date { font-size: 0.85rem; color: #666666; font-weight: 500; margin-top: 4px; }

        @media (max-width: 768px) {
            .site-header { flex-direction: column; align-items: stretch; gap: 16px; }
            .search-container { max-width: 100%; }
            .search-input { padding-left: 155px; }
            .auth-actions { justify-content: space-between; }
            .nav-menu { justify-content: flex-start; }
            .article-card { flex-direction: column; gap: 15px; }
            .thumbnail-wrapper { width: 100%; height: 200px; }
        }
    </style>
</head>
<body>

    <!-- Precise Wirecutter Global Header Layout -->
    <header class="site-header">
        <a href="/" class="logo-container">
            <span class="logo-t">T</span>
            <div class="logo-divider"></div>
            <span class="logo-text">Wirecutter</span>
        </a>
        
        <!-- Pill Shaped Active Search Input Field -->
        <div class="search-container">
            <div class="search-badge">
                <span class="star-icon">✦</span> Ask Wirecutter Finder
            </div>
            <input 
                type="text" 
                id="directorySearch" 
                class="search-input" 
                placeholder="Gift ideas for a baby shower" 
                autocomplete="off"
            />
        </div>

        <div class="auth-actions">
            <a href="#" class="btn-signup">Sign up</a>
            <a href="#" class="btn-login">Log in</a>
        </div>
    </header>

    <!-- Navigation Menu Row -->
    <nav class="nav-menu">
        <a href="/" class="nav-link">Prime Day</a>
        <a href="#" class="nav-link">Home & Garden</a>
        <a href="#" class="nav-link">Kitchen</a>
        <a href="#" class="nav-link">Health & Lifestyle</a>
        <a href="#" class="nav-link">Tech</a>
        <a href="#" class="nav-link">Baby & Kid</a>
        <a href="#" class="nav-link">Style</a>
        <a href="#" class="nav-link">Gifts</a>
        <a href="#" class="nav-link">Wirecutter Store</a>
    </nav>

    <!-- Disclaimer Info Bar component -->
    <div class="disclaimer-section">
        <p class="disclaimer-text">
            We independently review everything we recommend. When you buy through our links, we may earn a commission. <strong>Learn more ›</strong>
        </p>
    </div>

    <!-- The exact solid line element separator from image_30a7c4.png -->
    <hr class="header-bottom-line" />

    <!-- Main Content Review Feed Engine layout -->
    <h1 class="section-title">All Reviews</h1>

    <main class="articles-list">
        {Array.isArray(posts) && posts.map((post) => {
            let brandSlug = '';
            let modelSlug = '';
            
            const embeddedTerms = post._embedded?.['wp:term'] || [];
            embeddedTerms.forEach((taxonomyGroup) => {
              if (Array.isArray(taxonomyGroup)) {
                taxonomyGroup.forEach((term) => {
                  if (term.taxonomy === 'brands') brandSlug = term.slug;
                  if (term.taxonomy === 'models') modelSlug = term.slug;
                });
              }
            });

            const hrefPath = brandSlug 
                ? `/${brandSlug}/${modelSlug ? modelSlug : 'all'}/${post.slug}` 
                : `/${post.slug}`;

            const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
            const searchHaystack = `${post.title?.rendered} ${post.content?.rendered || ''} ${brandSlug} ${modelSlug}`.toLowerCase();

            return (
                <article class="article-card" data-search-content={searchHaystack}>
                    <div class="thumbnail-wrapper">
                        {featuredImage ? (
                            <img src={featuredImage} alt={post.title?.rendered} loading="lazy" />
                        ) : (
                            <div style="width:100%; height:100%; background:#eaeaea; display:flex; align-items:center; justify-content:center; color:#999; font-size:0.9rem;">No Image</div>
                        )}
                    </div>

                    <div class="content-block">
                        <h2 class="article-title">
                            <a href={hrefPath} set:html={post.title?.rendered} />
                        </h2>
                        
                        <!-- Smart Dynamic Content Excerpt Extractor -->
                        <div class="excerpt">
                          {post.excerpt?.rendered && post.excerpt.rendered.trim() !== "" ? (
                            <span set:html={post.excerpt.rendered} />
                          ) : (
                            /* Strips HTML tags from the full content body and cuts it cleanly at 160 characters */
                            <span>
                              {post.content?.rendered 
                                ? post.content.rendered.replace(/<\/?[^>]+(>|$)/g, "").substring(0, 160) + "..."
                                : "Read our deep breakdown and troubleshooting diagnosis steps for this bike entry."}
                            </span>
                          )}
                        </div>
                        
                        <p class="updated-date">{formatDate(post.date)}</p>
                    </div>
                </article>
            );
        })}
    </main>

    <!-- Fast Client-Side Instant Content Filtering Script -->
    <script>
        const searchInput = document.getElementById('directorySearch');
        const cards = document.querySelectorAll('.article-card');

        if (searchInput) {
            searchInput.addEventListener('input', (e) => {
                const query = e.target.value.toLowerCase().trim();
                cards.forEach(card => {
                    const content = card.getAttribute('data-search-content') || '';
                    card.style.display = content.includes(query) ? 'flex' : 'none';
                });
            });
        }
    </script>

</body>
</html>