---
export async function getStaticPaths() {
  const apiUrl = import.meta.env.WORDPRESS_API_URL || 'https://macho-newsletter.localsite.io/?rest_route=';
  
  try {
    const basicAuth = btoa('journey:robust');
    const res = await fetch(`${apiUrl}/wp/v2/symptoms&per_page=100&_embed`, {
      headers: {
        'Authorization': `Basic ${basicAuth}`
      }
    });
    
    const posts = await res.json();
    if (Array.isArray(posts)) {
      return posts.map((post) => {
        let brandSlug = '';
        let modelSlug = '';
        
        // Extract embedded taxonomy term layers safely
        const embeddedTerms = post._embedded?.['wp:term'] || [];
        
        // Loop over the groups to locate your custom taxonomy items
        embeddedTerms.forEach((taxonomyGroup) => {
          if (Array.isArray(taxonomyGroup)) {
            taxonomyGroup.forEach((term) => {
              if (term.taxonomy === 'brands') {
                brandSlug = term.slug;
              }
              if (term.taxonomy === 'models') {
                modelSlug = term.slug;
              }
            });
          }
        });
        
        // Construct paths cleanly: brand/model/post-slug -> giant/talon/chain-skipping
        // Falls back safely if an article is left untagged
        let finalPath = post.slug;
        if (brandSlug && modelSlug) {
          finalPath = `${brandSlug}/${modelSlug}/${post.slug}`;
        } else if (brandSlug) {
          finalPath = `${brandSlug}/all/${post.slug}`;
        }
        
        return {
          params: { path: finalPath },
          props: { post },
        };
      });
    }
  } catch (error) {
    console.error("Failed to compile custom taxonomy paths:", error);
  }

  return [];
}

const { post } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{post?.title?.rendered || 'Loading...'}</title>
    <style>
        body {
            font-family: system-ui, sans-serif;
            max-width: 800px;
            margin: 40px auto;
            padding: 0 20px;
            line-height: 1.6;
            color: #333;
        }
        h1 {
            color: #111;
            border-bottom: 2px solid #eee;
            padding-bottom: 10px;
        }
        .content {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    {post ? (
      <a href="/">← Back to Home</a>
      <h1>{post.title.rendered}</h1>
      <div class="content" set:html={post.content.rendered} />
    ) : (
      <h1>Post compilation error</h1>
    )}
</body>
</html>